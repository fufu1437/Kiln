{
	"name": "@fufu1437/kiln",
	"version": "0.0.16",
	"description": "A CMake configuration generation tool that uses TypeScript as its configuration language ",
	"scripts": {
		"build": "tsc",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"cmake",
		"build-tool",
		"kiln"
	],
	"homepage": "https://github.com/fufu1437/Kiln#readme",
	"bugs": {
		"url": "https://github.com/fufu1437/Kiln/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fufu1437/Kiln.git"
	},
	"license": "LGPL-3.0-only",
	"author": "fufu1437 (https://github.com/fufu1437)",
	"type": "module",
	"main": "dist/kiln.js",
	"types": "dist/kiln.d.ts",
	"bin": {
		"kiln": "bin/kiln"
	},
	"directories": {
		"doc": "doc",
		"test": "test"
	},
	"files": [
		"dist",
		"bin",
		"README.md",
		"CHANGELOG.md",
		"languages",
		"!**/*.map",
		"!*.txt"
	],
	"dependencies": {
		"undici-types": "^7.24.6"
	},
	"devDependencies": {
		"@types/node": "^25.9.1"
	}
}
